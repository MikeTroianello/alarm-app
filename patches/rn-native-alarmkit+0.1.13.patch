+<?xml version="1.0" encoding="utf-8"?>
+<manifest xmlns:android="http://schemas.android.com/apk/res/android"
+    package="com.nativealarms" >
+
+    <uses-sdk android:minSdkVersion="24" />
+
+    <!-- Permissions -->
+    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
+    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
+    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
+    <uses-permission android:name="android.permission.WAKE_LOCK" />
+    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
+    <uses-permission android:name="android.permission.VIBRATE" />
+
+    <application>
+
+        <!-- Alarm Receiver - Handles alarm trigger events -->
+        <receiver
+            android:name="com.nativealarms.AlarmReceiver"
+            android:enabled="true"
+            android:exported="false" >
+            <intent-filter>
+                <action android:name="com.nativealarms.ALARM_ACTION" />
+            </intent-filter>
+        </receiver>
+
+        <!-- Alarm Action Receiver - Handles notification actions -->
+        <receiver
+            android:name="com.nativealarms.AlarmActionReceiver"
+            android:enabled="true"
+            android:exported="false" >
+            <intent-filter>
+                <action android:name="com.nativealarms.ACTION_DISMISS" />
+                <action android:name="com.nativealarms.ACTION_SNOOZE" />
+            </intent-filter>
+        </receiver>
+
+        <!-- Boot Receiver - Reschedules alarms after reboot -->
+        <receiver
+            android:name="com.nativealarms.BootReceiver"
+            android:enabled="true"
+            android:exported="true" >
+            <intent-filter>
+                <action android:name="android.intent.action.BOOT_COMPLETED" />
+                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
+            </intent-filter>
+        </receiver>
+
+        <!-- Permission Receiver - Listens for permission changes (Android 12+) -->
+        <receiver
+            android:name="com.nativealarms.PermissionReceiver"
+            android:enabled="true"
+            android:exported="false" >
+            <intent-filter>
+                <action android:name="android.app.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
+            </intent-filter>
+        </receiver>
+    </application>
+
+</manifest>
